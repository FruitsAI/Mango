/packages/*/dist
/packages/*/src/**/*.js
/packages/*/src/**/*.d.ts

# misc
.DS_Store
*.pem
.worktrees/
/.turbo
**/.turbo
.eslintcache

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
