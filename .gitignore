# dependencies
/node_modules
**/node_modules
/.pnp
.pnp.js
.pnpm-store

# testing
/coverage
/test-results
/playwright-report

# next.js
/.next/
/out/

# production
/build
/apps/desktop/dist
/apps/desktop/out
/apps/*/dist
