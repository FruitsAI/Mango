    "@fontsource/syne": "^5.1.1",
    "@mango/adapters": "workspace:*",
    "@mango/contracts": "workspace:*",
    "@mango/core": "workspace:*",
    "@mango/ui": "workspace:*",
    "better-sqlite3": "^12.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
